<?xml version="1.0" ?>
<robot name="roll-e" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find labsim)/labsim/urdf/roll_e.gazebo" />
    <link name = "base_footprint">
        <!-- Nth in here -->
    </link>
    <joint name = "body_link_joint" type='fixed'>
        <!-- <origin xyz="0 0.00 0.1565" rpy="0 0 0"/> -->
        <origin xyz="0 0 0" rpy="0 0 3.142"/>
        <parent link="base_footprint"/>
        <child link="chassis"/>
    </joint>
    
    <!--BASE LINK-->
    <link name="chassis">
        <visual>
            <geometry>
                <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-chassis.dae" scale=" 1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <density>1060.0</density>
           <origin xyz="0 0 0"/>
           <geometry>
              <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-chassis.dae" scale=" 1 1 1"/>
           </geometry>
        </collision>
        <inertial>
            <mass value="0.29"/>
            <origin xyz="0 0 0"/>
            <!-- <inertia ixx="0.000193" ixy="0.0" ixz="0.0" iyy="0.000694" iyz="0.0" izz="0.000529"/> -->
            <inertia
            ixx="0.0262" ixy="0.0" ixz="0.0"
            iyy="0.0340" iyz="0.0"
            izz="0.0438"/>
        </inertial>
    </link>

    <!--CAMERAS-->

    <joint name="lidar_mount" type="fixed">
        <origin xyz = "-0.158 -0.0025 0.1599" rpy=" 0 0.0 3.142"/>
        <parent link="chassis"/>
        <child link="d_lidar"/>
    </joint>

    <link name="d_lidar">
       <inertial>
            <mass value="0.01"/>
            <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
       </inertial>
    </link>

        <!-- Continuous spin joint (Z axis) -->
    <joint name="lidar_spin_joint" type="continuous">
        <limit lower="-3.1415" upper="3.1415" effort="150" velocity="50.0"/>
        <parent link="chassis"/>
        <child link="UTL2"/>

        <!-- adjust this pose if the lidar is offset from chassis -->
        <origin xyz = "-0.158 -0.0025 0.1599" rpy=" 0 0.0 3.142"/>

        <!-- spin about +Z -->
        <axis xyz="0 0 1"/>

        <dynamics damping="0.0" friction="0.0"/>
    </joint>

    <link name="UTL2">
       <inertial>
            <mass value="0.01"/>
            <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
       </inertial>
    </link>


    <joint name="camera_mount" type="fixed">
        <origin xyz = "-0.15 -0.0025 0.14955" rpy=" 0 0.0 3.142"/>
        <parent link="chassis"/>
        <child link="d_camera"/>
    </joint>

    <link name="d_camera">
       <inertial>
            <mass value="0.01"/>
            <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
       </inertial>
    </link>


    <joint name="camera_mount_01" type="fixed">
        <origin xyz = "-0.15 -0.0025 0.14955" rpy=" 0 0.0 3.142"/>
        <parent link="chassis"/>
        <child link="camera01"/>
    </joint>

    <link name="camera01">
       <inertial>
            <mass value="0.01"/>
            <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
       </inertial>
    </link>


    <!--LEFT WHEELS-->
    <!--WHEEL 01-->

    <joint name = "fl" type='continuous'>
        <!-- <origin xyz="0 0.00 0.1565" rpy="0 0 0"/> -->
        <origin xyz="-0.069 -0.1234 0.03156" rpy="0 0 0"/>
        <parent link="chassis"/>        <axis xyz="0 1 0"/>
        <limit lower="-3.1415" upper="3.1415" effort="150" velocity="50.0"/>
        <child link="wheell1"/>
    </joint>

    <link name="wheell1">
        <visual>
            <geometry>
                <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <density>1760.0</density>
           <origin xyz="0 0 0"/>
           <geometry>
              <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
           </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <origin xyz="0 0 0"/>
             <inertia
            ixx="0.000137" ixy="0.0" ixz="0.0"
            iyy="0.000137" iyz="0.0"
            izz="0.000194"/>
        </inertial>
    </link>

    <!--WHEEL 02-->

    <joint name = "ml" type='continuous'>
        <!-- <origin xyz="0 0.00 0.1565" rpy="0 0 0"/> -->
        <origin xyz="0.0130 -0.1234 0.03156" rpy="0 0 0"/>
        <parent link="chassis"/>        <axis xyz="0 1 0"/>
        <limit lower="-3.1415" upper="3.1415" effort="150" velocity="50.0"/>
        <child link="wheell2"/>
    </joint>

    <link name="wheell2">
        <visual>
            <geometry>
                <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <density>1760.0</density>
           <origin xyz="0 0 0"/>
           <geometry>
              <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
           </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <origin xyz="0 0 0"/>
             <inertia
            ixx="0.000137" ixy="0.0" ixz="0.0"
            iyy="0.000137" iyz="0.0"
            izz="0.000194"/>
        </inertial>
    </link>

     <!--WHEEL 03-->

    <joint name = "rl" type='continuous'>
        <!-- <origin xyz="0 0.00 0.1565" rpy="0 0 0"/> -->
        <origin xyz="0.10775 -0.1234 0.03156" rpy="0 0 0"/>
        <parent link="chassis"/>        <axis xyz="0 1 0"/>
        <limit lower="-3.1415" upper="3.1415" effort="150" velocity="50.0"/>
        
        <child link="wheell3"/>
    </joint>

    <link name="wheell3">
        <visual>
            <geometry>
                <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <density>1760.0</density>
           <origin xyz="0 0 0"/>
           <geometry>
              <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
           </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <origin xyz="0 0 0"/>
             <inertia
            ixx="0.000137" ixy="0.0" ixz="0.0"
            iyy="0.000137" iyz="0.0"
            izz="0.000194"/>
        </inertial>
    </link>


    <!--RIGHT WHEELS-->
    <!--WHEEL 01-->

    <joint name = "fr" type='continuous'>
        <!-- <origin xyz="0 0.00 0.1565" rpy="0 0 0"/> -->
        <origin xyz="-0.069 0.116 0.03156" rpy="3.1415926536 0 0"/>
        <parent link="chassis"/>        <axis xyz="0 1 0"/>
        <limit lower="-3.1415" upper="3.1415" effort="150" velocity="50.0"/>
        <child link="wheelr1"/>
    </joint>

    <link name="wheelr1">
        <visual>
            <geometry>
                <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <density>1760.0</density>
           <origin xyz="0 0 0"/>
           <geometry>
              <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
           </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <origin xyz="0 0 0"/>
             <inertia
            ixx="0.000137" ixy="0.0" ixz="0.0"
            iyy="0.000137" iyz="0.0"
            izz="0.000194"/>
        </inertial>
    </link>

    <!--WHEEL 02-->

    <joint name = "mr" type='continuous'>
        <!-- <origin xyz="0 0.00 0.1565" rpy="0 0 0"/> -->
        <origin xyz="0.0130 0.116 0.03156" rpy="3.1415926536 0 0"/>
        <parent link="chassis"/>        <axis xyz="0 1 0"/>
        <limit lower="-3.1415" upper="3.1415" effort="150" velocity="50.0"/>
        <child link="wheelr2"/>
    </joint>

    <link name="wheelr2">
        <visual>
            <geometry>
                <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <density>1760.0</density>
           <origin xyz="0 0 0"/>
           <geometry>
              <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
           </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <origin xyz="0 0 0"/>
             <inertia
            ixx="0.000137" ixy="0.0" ixz="0.0"
            iyy="0.000137" iyz="0.0"
            izz="0.000194"/>
        </inertial>
    </link>

     <!--WHEEL 03-->

    <joint name = "rr" type='continuous'>
        <!-- <origin xyz="0 0.00 0.1565" rpy="0 0 0"/> -->
        <origin xyz="0.10775 0.116 0.03156" rpy="3.1415926536 0 0"/>
        <parent link="chassis"/>        <axis xyz="0 1 0"/>
        <limit lower="-3.1415" upper="3.1415" effort="150" velocity="50.0"/>
        <child link="wheelr3"/>
    </joint>

    <link name="wheelr3">
        <visual>
            <geometry>
                <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <density>1760.0</density>
           <origin xyz="0 0 0"/>
           <geometry>
              <mesh filename="$(find labsim)/labsim/urdf/designs/roll-e-wheel.dae" scale=" 1 1 1"/>
           </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <origin xyz="0 0 0"/>
             <inertia
            ixx="0.000137" ixy="0.0" ixz="0.0"
            iyy="0.000137" iyz="0.0"
            izz="0.000194"/>
        </inertial>
    </link>



</robot>